<?xml version="1.0" encoding="UTF-8"?>
<!--This does not replace URDF, and is not an extension of URDF.
    This is a format for representing semantic information about the robot structure.
    A URDF file must exist for this robot as well, where the joints and the links that are referenced are defined
-->
<robot name="zmebot">
    <!--DISABLE COLLISIONS: By default it is assumed that any link of the robot could potentially come into collision with any other link in the robot. This tag disables collision checking between a specified pair of links. -->
    <disable_collisions link1="base_link" link2="lifting_base_link" reason="Adjacent"/>
    <disable_collisions link1="base_link" link2="left_link1" reason="Never"/>
    <disable_collisions link1="base_link" link2="left_link2" reason="Never"/>
    <disable_collisions link1="base_link" link2="left_link3" reason="Never"/>
    <disable_collisions link1="base_link" link2="left_link4" reason="Never"/>
    <disable_collisions link1="base_link" link2="left_link5" reason="Never"/>
    <disable_collisions link1="base_link" link2="left_link6" reason="Never"/>
    <disable_collisions link1="base_link" link2="right_link1" reason="Never"/>
    <disable_collisions link1="base_link" link2="right_link2" reason="Never"/>
    <disable_collisions link1="base_link" link2="right_link3" reason="Never"/>
    <disable_collisions link1="base_link" link2="right_link4" reason="Never"/>
    <disable_collisions link1="base_link" link2="right_link5" reason="Never"/>
    <disable_collisions link1="base_link" link2="right_link6" reason="Never"/>
